generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  FRONTDESK
  FINANCE
  HOUSEKEEPING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ConversationState {
  NEW
  QUALIFYING
  QUOTED
  PAYMENT_PENDING
  CONFIRMED
  CLOSED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  REQUIRES_ACTION
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  /// Local purchase order — B2B / company billing; follow-up via finance
  LPO
  /// Payment initiated by guest via bank transfer to friend/contact (manual reconciliation)
  FRIENDS_TRANSFER
}

enum PaymentKind {
  SUBSCRIPTION
  BOOKING
}

enum ChannelProvider {
  BOOKING_COM
  AIRBNB
  EXPEDIA
  DIRECT
  WHATSAPP
  PHONE
  CORPORATE
  REFERRAL
}

/// Hospitality CRM-style guest labels; combined with SegmentTagSource for manual vs rules engine.
enum SegmentTagKind {
  REPEAT_GUEST
  FAMILY
  CORPORATE
  LONG_STAY
  HIGH_SPENDER
  OTA_GUEST
  DIRECT_GUEST
  WHATSAPP_GUEST
  WALK_IN
  PHONE_BOOKING
  REFERRAL
  OTHER
}

enum SegmentTagSource {
  MANUAL
  AUTO
}

enum SyncStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

enum FbOutletType {
  RESTAURANT
  COFFEE_SHOP
}

enum FbServiceMode {
  ROOM_SERVICE
  DINING_IN
}

enum FbOrderStatus {
  POSTED
  VOID
}

/// Lightweight kitchen / outlet ticket lifecycle (internal ops; not full POS).
enum OutletTicketStatus {
  NEW
  ACKNOWLEDGED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum OutletTicketSource {
  FB_MENU
  FOLIO_CHARGE
}

/// Ledger lines for room-unit folio (charges, desk payments, adjustments) — reportable, soft-void only.
/// Extended with REFUND / DISCOUNT for proper accounting (no silent edits to original lines).
enum FolioTransactionType {
  FNB_CHARGE
  ACTIVITY_CHARGE
  OTHER_SERVICE_CHARGE
  PAYMENT
  ADJUSTMENT
  REFUND
  DISCOUNT
}

enum FolioOutletCategory {
  RESTAURANT
  CAFE
  ACTIVITY
  ROOM_SERVICE
  OTHER
}

enum FolioPostingTarget {
  GUEST_FOLIO
  BOOKING_ACCOUNT
  ROOM_ACCOUNT
}

enum FolioTxnPaymentStatus {
  UNPAID
  PAID
  VOIDED
  REFUNDED
  PENDING
  PARTIALLY_PAID
}

/// Canonical ledger kind for reporting, POS mapping, and AI (mirrors FolioTransactionType but richer taxonomy).
enum FolioLedgerKind {
  ROOM_CHARGE
  FNB_CHARGE
  ACTIVITY_CHARGE
  SERVICE_CHARGE
  PAYMENT
  ADJUSTMENT
  DISCOUNT
  REFUND
  TAX
  FEE
}

/// Revenue / outlet grouping for P&L and outlet reports (normalized; prefer over free text).
enum FolioRevenueCategory {
  ACCOMMODATION
  RESTAURANT
  CAFE
  ROOM_SERVICE
  ACTIVITY
  LAUNDRY
  TRANSPORT
  MINIBAR
  OTHER
}

/// Origin of the posting — audit, POS reconciliation, automation.
enum FolioTxnSourceType {
  MANUAL_FRONTDESK
  ADMIN_PANEL
  WHATSAPP_BOOKING
  POS_RESTAURANT
  POS_CAFE
  ACTIVITY_DESK
  SYSTEM_AUTO
  API
}

enum FolioStatus {
  OPEN
  CLOSED
  SETTLED
  DISPUTED
  CANCELLED
}

/// Staff / guest notification queue (Phase 1: persistence only; delivery wiring comes later).
enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum OutletKind {
  RESTAURANT
  CAFE
  ACTIVITY
  ROOM_SERVICE
  OTHER
}

/// Housekeeping queue: assignment, audit trail, and cleaner accountability (PMS-style).
enum HousekeepingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum HousekeepingTaskSource {
  CHECKOUT
  MANUAL
  FRONTDESK
}

/// How the current assignee was chosen (audit / operations).
enum HousekeepingAssignmentMode {
  AUTO
  MANUAL
  SELF_CLAIMED
}

model Hotel {
  id             String                  @id @default(cuid())
  slug           String                  @unique
  legalName      String
  displayName    String
  city           String?
  country        String                  @default("OM")
  timezone       String                  @default("Asia/Muscat")
  currency       String                  @default("OMR")
  whatsappPhone  String?
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  users          HotelUser[]
  properties     Property[]
  roomTypes      RoomType[]
  roomUnits      RoomUnit[]
  inventories    Inventory[]
  guests         Guest[]
  conversations  Conversation[]
  messages       Message[]
  bookings       Booking[]
  bookingGroups  BookingGroup[]
  subscriptions  Subscription[]
  invoices       Invoice[]
  paymentIntents PaymentIntent[]
  paymentTransactions PaymentTransaction[]
  integrations   IntegrationConnection[]
  auditLogs      AuditLog[]
  conversationSessions ConversationSession[]
  bookingDrafts  BookingDraft[]
  calendarSessions CalendarSession[]
  menuItems      MenuItem[]
  fbOrders       FbOrder[]
  fbOperationalExpenses FbOperationalExpense[]
  outletOrderTickets OutletOrderTicket[]
  folioTransactions FolioTransaction[]
  folios         Folio[]
  outlets        Outlet[]
  outletMenuItems OutletMenuItem[]
  paymentAllocations PaymentAllocation[]
  bookingStatusHistories BookingStatusHistory[]
  notifications         Notification[]
  guestFollowUps        GuestFollowUp[]
  marketingCampaigns    MarketingCampaign[]
  hotelDailyDigestLogs  HotelDailyDigestLog[]
  frontDeskShifts       FrontDeskShift[]
  housekeepingTasks     HousekeepingTask[]
  leads                Lead[]
  leadOutreachLogs     LeadOutreachLog[]
}

/// Per-hotel daily email digest audit (hotel admin); separate from platform OwnerDailyDigestLog.
model HotelDailyDigestLog {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  digestKey     String
  status        String
  recipientsCsv String?
  subject       String?
  errorMessage  String?
  summaryJson   String?
  sentAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([hotelId, digestKey])
}

model HotelUser {
  id           String   @id @default(cuid())
  hotelId      String
  hotel        Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  fullName     String
  email        String?
  username     String?
  pinHash      String?
  passwordHash String
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  passwordResetRequestedAt DateTime?
  lastLoginAt  DateTime?
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([hotelId, email])
  @@unique([hotelId, username])
  folioTxnsCreated FolioTransaction[] @relation("FolioTxnCreatedBy")
  folioTxnsVoided  FolioTransaction[] @relation("FolioTxnVoidedBy")
  folioTxnsUpdated FolioTransaction[] @relation("FolioTxnUpdatedBy")
  foliosCreated    Folio[]            @relation("FolioCreatedBy")
  bookingStatusHistories BookingStatusHistory[]
  notifications          Notification[]
  closedFrontDeskShifts  FrontDeskShift[] @relation("ShiftClosedBy")
  fbOperationalExpensesCreated FbOperationalExpense[] @relation("FbOpExpenseCreatedBy")
  hkTasksAssigned              HousekeepingTask[]     @relation("HKTaskAssignedTo")
  hkTasksCreated               HousekeepingTask[]     @relation("HKTaskCreatedBy")
  hkTasksCompleted             HousekeepingTask[]     @relation("HKTaskCompletedBy")
  hkTasksManualAssigned        HousekeepingTask[]     @relation("HKTaskManualAssignedBy")
  passwordResetTokens          PasswordResetToken[]
}

/// Single-use password reset challenge for email-based auth.
model PasswordResetToken {
  id          String    @id @default(cuid())
  hotelUserId String
  hotelUser   HotelUser @relation(fields: [hotelUserId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedIp String?
  createdAt   DateTime  @default(now())

  @@index([hotelUserId, createdAt])
  @@index([expiresAt])
}

/// Locked cashier / front-desk shift close with cash reconciliation (folio-based).
model FrontDeskShift {
  id                  String   @id @default(cuid())
  hotelId             String
  hotel               Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  /// MORNING | EVENING | NIGHT | CUSTOM — multiple shifts per day use distinct slots.
  shiftSlot           String   @default("CUSTOM")
  /// Optional label when slot is CUSTOM or for display (e.g. "Pre-convention").
  shiftLabel          String?
  /// Civil date (YYYY-MM-DD) for filtering; should align with property operations day.
  businessDate        String   @default("1970-01-01")
  shiftStart          DateTime
  shiftEnd            DateTime
  closedAt            DateTime
  closedByUserId      String?
  closedBy            HotelUser? @relation("ShiftClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  openingCash         Float
  closingCashActual   Float
  bankDepositAmount   Float    @default(0)
  expectedClosingCash Float
  cashVariance        Float
  currency            String   @default("OMR")
  status              String   @default("CLOSED")
  locked              Boolean  @default(true)
  /// MANUAL | CARRY_FROM_PRIOR — opening float entry mode
  openingCashSource   String   @default("MANUAL")
  /// Previous closed shift this session continued from (cashier handover chain).
  priorShiftId        String?
  priorShift            FrontDeskShift?  @relation("ShiftHandover", fields: [priorShiftId], references: [id], onDelete: SetNull)
  nextShifts            FrontDeskShift[] @relation("ShiftHandover")
  handoverNote        String?
  /// Audit: auto totals + payment buckets + charge splits + outstanding snapshot at close
  snapshotJson        String
  expenses            FrontDeskShiftExpense[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([hotelId, closedAt])
  @@index([hotelId, shiftStart])
  @@index([hotelId, businessDate])
}

model FrontDeskShiftExpense {
  id        String         @id @default(cuid())
  shiftId   String
  shift     FrontDeskShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  category  String
  amount    Float
  note      String?
  createdAt DateTime       @default(now())
}

model Property {
  id            String     @id @default(cuid())
  hotelId        String
  hotel          Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name           String
  city           String?
  addressLine1   String?
  checkInTime    String?
  checkOutTime   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  roomTypes      RoomType[]
  inventories    Inventory[]
  bookings       Booking[]
  conversations  Conversation[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  guestFollowUps GuestFollowUp[]
  convertedLeads Lead[]
  leadOutreachLogs LeadOutreachLog[]

  @@unique([hotelId, name])
}

model Lead {
  id                String   @id @default(cuid())
  hotelId           String
  hotel             Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  convertedPropertyId String?
  convertedProperty Property? @relation(fields: [convertedPropertyId], references: [id], onDelete: SetNull)
  hotelName         String
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  location          String?
  source            String   @default("manual")
  status            String   @default("new")
  lastContactedAt   DateTime?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  outreachLogs      LeadOutreachLog[]

  @@index([hotelId, status, createdAt])
  @@index([hotelId, contactEmail])
  @@index([hotelId, contactPhone])
}

model LeadOutreachLog {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel       String
  templateKey   String
  messageBody   String
  status        String   @default("SENT")
  responseStatus String? @default("pending")
  sentAt        DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([hotelId, leadId, createdAt])
  @@index([hotelId, channel, sentAt])
}

model RoomType {
  id             String      @id @default(cuid())
  hotelId         String
  hotel           Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name            String
  code            String
  capacity        Int         @default(2)
  baseNightlyRate Float
  totalInventory  Int         @default(1)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  inventory       Inventory[]
  bookings        Booking[]
  roomUnits       RoomUnit[]
  channelMappings ChannelMapping[]
  folioTransactions FolioTransaction[]

  @@unique([propertyId, code])
}

model Inventory {
  id            String   @id @default(cuid())
  hotelId       String
  hotel         Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTypeId    String
  roomType      RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  date          DateTime
  total         Int
  reserved      Int      @default(0)
  closedOut     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([roomTypeId, date])
}

model Guest {
  id            String         @id @default(cuid())
  hotelId        String
  hotel          Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  fullName       String?
  phoneE164      String
  email          String?
  /// ISO nationality / country of passport (optional; front desk & reporting).
  nationality    String?
  locale         String?        @default("en")
  /// Guest journey: last REPEAT_GUEST_PROMO sent (cooldown across bookings at this hotel).
  journeyLastRepeatPromoAt DateTime?
  /// Staff-marked VIP; used for badges and future differentiated handling.
  isVip          Boolean        @default(false)
  /// Short internal note shown with VIP (preferences, recognition cues).
  vipNote        String?
  /// Rule-based WhatsApp personalization: preferences, repeat signals, spending band (JSON). No PII beyond what Guest already stores.
  lightGuestMemoryJson String?
  segmentTags    GuestSegmentTag[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversations  Conversation[]
  bookings       Booking[]
  conversationSessions ConversationSession[]
  bookingDrafts  BookingDraft[]
  calendarSessions CalendarSession[]
  fbOrders       FbOrder[]
  outletOrderTickets OutletOrderTicket[]
  folioTransactions FolioTransaction[]
  folios         Folio[]
  notifications  Notification[]
  guestFollowUps GuestFollowUp[]
  marketingCampaignRecipients MarketingCampaignRecipient[]

  @@unique([hotelId, phoneE164])
}

/// Targeted WhatsApp campaign (filters JSON + aggregates + per-guest outcomes).
model MarketingCampaign {
  id                  String   @id @default(cuid())
  hotelId             String
  hotel               Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name                String
  purposeNote         String?
  filtersJson         String
  messageBody         String
  linkedOfferId       String?
  channel             String   @default("WHATSAPP")
  /// DRAFT | SENT | FAILED
  status              String   @default("DRAFT")
  audienceCount       Int      @default(0)
  attemptedCount      Int      @default(0)
  sentOkCount         Int      @default(0)
  sentFailedCount     Int      @default(0)
  skippedNoPhoneCount Int      @default(0)
  createdAt           DateTime @default(now())
  sentAt              DateTime?
  recipients          MarketingCampaignRecipient[]

  @@index([hotelId, createdAt])
}

model MarketingCampaignRecipient {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  guestId     String
  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  outcome     String
  errorDetail String?
  createdAt   DateTime @default(now())

  @@unique([campaignId, guestId])
  @@index([campaignId])
}

/// One row per guest per tag; unique (guestId, tag). MANUAL rows are preserved; AUTO rows refreshed by rules.
model GuestSegmentTag {
  id        String           @id @default(cuid())
  guestId   String
  guest     Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tag       SegmentTagKind
  source    SegmentTagSource
  createdAt DateTime         @default(now())

  @@unique([guestId, tag])
  @@index([guestId])
}

model Conversation {
  id            String            @id @default(cuid())
  hotelId       String
  hotel         Hotel             @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  propertyId    String?
  property      Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  guestId       String
  guest         Guest             @relation(fields: [guestId], references: [id], onDelete: Cascade)
  channel       ChannelProvider   @default(DIRECT)
  state           ConversationState @default(NEW)
  agentHandoffAt  DateTime?
  lastMessageAt   DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  messages        Message[]
  bookings      Booking[]
  sessions      ConversationSession[]
  bookingDrafts BookingDraft[]
  guestFollowUps GuestFollowUp[]
}

model Message {
  id             String           @id @default(cuid())
  hotelId        String
  hotel          Hotel            @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  providerMessageId String?
  direction      MessageDirection
  body           String
  aiIntent       String?
  aiConfidence   Float?
  createdAt      DateTime         @default(now())

  @@unique([conversationId, providerMessageId])
}

/// Links multiple room bookings under one payer / account (family or group). Optional; null = standalone booking.
model BookingGroup {
  id        String    @id @default(cuid())
  hotelId   String
  hotel     Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  label     String?
  createdAt DateTime  @default(now())
  bookings  Booking[]

  @@index([hotelId, createdAt])
}

model Booking {
  id             String        @id @default(cuid())
  hotelId        String
  hotel          Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  propertyId     String
  property       Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTypeId     String
  roomType       RoomType      @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  roomUnitId     String?
  roomUnit       RoomUnit?     @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  bookingGroupId String?
  bookingGroup   BookingGroup? @relation(fields: [bookingGroupId], references: [id], onDelete: SetNull)
  /// When part of a BookingGroup, marks the booking that owns invoicing / payer accountability in the UI (one per group).
  isPrimaryPayer Boolean       @default(false)
  guestId        String
  guest          Guest         @relation(fields: [guestId], references: [id], onDelete: Restrict)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  checkIn        DateTime
  checkOut       DateTime
  nights         Int
  adults         Int           @default(2)
  children       Int           @default(0)
  totalAmount    Float
  currency       String        @default("OMR")
  status         BookingStatus @default(PENDING)
  source         ChannelProvider @default(DIRECT)
  paymentStatus  PaymentStatus @default(PENDING)
  /// Human-friendly ref for staff & guests (e.g. WA-260404-001). Routes/APIs still use `id`.
  referenceCode  String?
  /// Meal package chosen in WhatsApp / desk: NONE, BREAKFAST, HALF_BOARD, FULL_BOARD.
  mealPlan       String?
  /// When the automated pre-arrival WhatsApp reminder was successfully sent (dedupes retries). Legacy; prefer guestJourneyPreArrival24hSentAt.
  preArrivalReminderSentAt DateTime?
  /// Guest journey: PRE_ARRIVAL_24H WhatsApp sent (once per booking).
  guestJourneyPreArrival24hSentAt DateTime?
  /// Guest journey: CHECKIN_DAY WhatsApp sent (once per booking).
  guestJourneyCheckinDaySentAt DateTime?
  /// Guest journey: POST_CHECKOUT_THANK_YOU WhatsApp sent (once per booking).
  guestJourneyPostCheckoutThankYouSentAt DateTime?
  /// Guest journey: REVIEW_REQUEST WhatsApp sent (once per booking).
  guestJourneyReviewRequestSentAt DateTime?
  /// Guest journey: REPEAT_GUEST_PROMO WhatsApp sent (once per booking; guest-level cooldown also applies).
  guestJourneyRepeatPromoSentAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  paymentIntents PaymentIntent[]
  bookingDraft   BookingDraft?
  fbOrders       FbOrder[]
  outletOrderTickets OutletOrderTicket[]
  folioTransactions FolioTransaction[]
  folios         Folio[]
  statusHistory  BookingStatusHistory[]
  auditLogEntries AuditLog[] @relation("BookingAuditLogs")
  housekeepingTasks HousekeepingTask[]
  guestFollowUps GuestFollowUp[]

  @@unique([hotelId, referenceCode])
  @@index([hotelId, referenceCode])
  @@index([hotelId, bookingGroupId])
}

/// Immutable log of booking lifecycle status changes (PMS audit / reporting).
model BookingStatusHistory {
  id           String         @id @default(cuid())
  hotelId      String
  hotel        Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookingId    String
  booking      Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromStatus   BookingStatus?
  toStatus     BookingStatus
  source       String         @default("SYSTEM")
  actorUserId  String?
  actorUser    HotelUser?     @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  note         String?
  createdAt    DateTime       @default(now())

  @@index([hotelId, bookingId])
  @@index([hotelId, createdAt])
}

/// Financial ledger container for a stay. Default MAIN folio per booking; structure allows split/company folios later.
model Folio {
  id              String      @id @default(cuid())
  hotelId         String
  hotel           Hotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookingId       String
  booking         Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guestId         String?
  guest           Guest?      @relation(fields: [guestId], references: [id], onDelete: SetNull)
  roomUnitId      String?
  roomUnit        RoomUnit?   @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  folioCode       String      @default("MAIN")
  folioStatus     FolioStatus @default(OPEN)
  currency        String      @default("OMR")
  openedAt        DateTime    @default(now())
  closedAt        DateTime?
  notes           String?
  createdByUserId String?
  createdBy       HotelUser?  @relation("FolioCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  transactions    FolioTransaction[]
  paymentAllocations PaymentAllocation[]

  @@unique([bookingId, folioCode])
  @@index([hotelId, bookingId])
  @@index([hotelId, folioStatus])
}

/// Master revenue outlets (POS / activity desks). MenuItem remains for legacy F&B orders; OutletMenuItem is the PMS catalog path.
model Outlet {
  id         String     @id @default(cuid())
  hotelId    String
  hotel      Hotel      @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  code       String
  name       String
  outletType OutletKind
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  menuItems  OutletMenuItem[]
  folioTransactions FolioTransaction[]

  @@unique([hotelId, code])
  @@index([hotelId, outletType, isActive])
}

model OutletMenuItem {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  outletId    String
  outlet      Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  itemCode    String
  itemName    String
  description String?
  category    String?
  unitPrice   Float
  taxRate     Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  folioTransactions FolioTransaction[]

  @@index([hotelId, outletId, isActive])
  @@index([hotelId, itemCode])
}

/// Optional FIFO / split application of a payment to specific charge lines (proper accounting, multi-line settlement).
model PaymentAllocation {
  id                     String   @id @default(cuid())
  hotelId                String
  hotel                  Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  folioId                String
  folio                  Folio    @relation(fields: [folioId], references: [id], onDelete: Cascade)
  paymentTransactionId   String
  paymentTransaction     FolioTransaction @relation("AllocPaymentTxn", fields: [paymentTransactionId], references: [id], onDelete: Restrict)
  appliedToTransactionId String?
  appliedToTransaction   FolioTransaction? @relation("AllocChargeTxn", fields: [appliedToTransactionId], references: [id], onDelete: SetNull)
  amountApplied          Float
  createdAt              DateTime @default(now())

  @@index([hotelId, folioId])
  @@index([paymentTransactionId])
  @@index([appliedToTransactionId])
}

model MenuItem {
  id          String       @id @default(cuid())
  hotelId     String
  hotel       Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  outletType  FbOutletType
  name        String
  description String?
  unitPrice   Float
  currency    String       @default("OMR")
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orderLines  FbOrderLine[]
  folioTransactions FolioTransaction[]

  @@index([hotelId, outletType, isActive])
}

model FbOrder {
  id          String        @id @default(cuid())
  hotelId     String
  hotel       Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookingId   String
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guestId     String
  guest       Guest         @relation(fields: [guestId], references: [id], onDelete: Restrict)
  outletType  FbOutletType
  serviceMode FbServiceMode
  status      FbOrderStatus @default(POSTED)
  totalAmount Float
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  lines       FbOrderLine[]
  outletOrderTicket OutletOrderTicket?

  @@index([hotelId, bookingId])
  @@index([guestId])
}

model FbOrderLine {
  id           String    @id @default(cuid())
  orderId      String
  order        FbOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId   String?
  menuItem     MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  itemNameSnap String
  quantity     Int
  unitPrice    Float
  lineTotal    Float

  @@index([orderId])
}

/// Grocery / supplies / F&B operating costs (not guest folio).
model FbOperationalExpense {
  id              String    @id @default(cuid())
  hotelId         String
  hotel           Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  expenseDate     DateTime
  amount          Float
  category        String
  outlet          String?
  paymentMethod   String?
  referenceNote   String?
  createdByUserId String?
  createdBy       HotelUser? @relation("FbOpExpenseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  @@index([hotelId, expenseDate])
}

/// Guest folio line item (blueprint name: FolioLine). Single ledger model — do not add a duplicate FolioLine table.
model FolioTransaction {
  id                 String                 @id @default(cuid())
  hotelId            String
  hotel              Hotel                  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  folioId            String?
  folio              Folio?                 @relation(fields: [folioId], references: [id], onDelete: SetNull)
  bookingId          String?
  booking            Booking?               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guestId            String?
  guest              Guest?                 @relation(fields: [guestId], references: [id], onDelete: SetNull)
  roomUnitId         String?
  roomUnit           RoomUnit?              @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  roomTypeId         String?
  roomType           RoomType?              @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)

  transactionType    FolioTransactionType
  /// Reporting / POS taxonomy (populated for new rows; legacy rows may be null until backfilled).
  ledgerKind         FolioLedgerKind?
  /// Normalized revenue bucket for outlet P&L (populated for new rows).
  revenueCategory    FolioRevenueCategory?
  sourceType         FolioTxnSourceType     @default(ADMIN_PANEL)

  outletCategory     FolioOutletCategory

  outletId           String?
  outlet             Outlet?                @relation(fields: [outletId], references: [id], onDelete: SetNull)
  outletMenuItemId   String?
  outletMenuItem     OutletMenuItem?        @relation(fields: [outletMenuItemId], references: [id], onDelete: SetNull)
  menuItemId         String?
  menuItem           MenuItem?              @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  itemCode           String?
  itemName           String
  description        String?

  quantity           Int                    @default(1)
  unitPrice          Float
  grossAmount        Float
  discountAmount     Float                  @default(0)
  taxAmount          Float                  @default(0)
  netAmount          Float

  currency           String                 @default("OMR")

  postingTarget      FolioPostingTarget     @default(BOOKING_ACCOUNT)

  folioPaymentStatus FolioTxnPaymentStatus  @default(UNPAID)
  folioPaymentMethod String?
  referenceNumber    String?

  chargeDate         DateTime               @default(now())
  /// When the service was consumed (distinct from postedAt / chargeDate when back-posting).
  serviceDate        DateTime?
  postedAt           DateTime               @default(now())
  effectiveDate      DateTime?

  notes              String?
  staffNote          String?
  internalNote       String?

  createdByUserId    String?
  createdBy          HotelUser?             @relation("FolioTxnCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId    String?
  updatedBy          HotelUser?             @relation("FolioTxnUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  voidedAt           DateTime?
  voidedByUserId     String?
  voidedBy           HotelUser?             @relation("FolioTxnVoidedBy", fields: [voidedByUserId], references: [id], onDelete: SetNull)
  voidReason         String?
  /// Denormalized for fast filtering; always in sync with voidedAt in application layer.
  isVoided           Boolean                @default(false)

  parentTransactionId String?
  parentTransaction   FolioTransaction?     @relation("FolioTxnParent", fields: [parentTransactionId], references: [id], onDelete: SetNull)
  childTransactions   FolioTransaction[]    @relation("FolioTxnParent")

  externalSourceId    String?
  externalSourcePayload String?

  allocationsAsPayment PaymentAllocation[]  @relation("AllocPaymentTxn")
  allocationsAsCharge  PaymentAllocation[]  @relation("AllocChargeTxn")

  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([hotelId, bookingId])
  @@index([hotelId, folioId])
  @@index([hotelId, folioId, chargeDate])
  @@index([hotelId, roomUnitId, chargeDate])
  @@index([bookingId, folioPaymentStatus])
  @@index([hotelId, ledgerKind])
  @@index([hotelId, revenueCategory])
  @@index([hotelId, sourceType])
  @@index([hotelId, isVoided])
  @@index([hotelId, chargeDate])
  @@index([parentTransactionId])

  outletOrderTicket OutletOrderTicket?
}

/// Internal outlet order ticket — one per FbOrder (menu POS) or per qualifying FolioTransaction (desk charge).
model OutletOrderTicket {
  id        String @id @default(cuid())
  hotelId   String
  hotel     Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  guestId   String?
  guest     Guest?  @relation(fields: [guestId], references: [id], onDelete: SetNull)

  source OutletTicketSource

  fbOrderId String?  @unique
  fbOrder   FbOrder? @relation(fields: [fbOrderId], references: [id], onDelete: Cascade)

  folioTransactionId String?           @unique
  folioTransaction   FolioTransaction? @relation(fields: [folioTransactionId], references: [id], onDelete: SetNull)

  /// Filter key: FbOutletType value or FolioOutletCategory name (e.g. RESTAURANT, COFFEE_SHOP, ROOM_SERVICE).
  outletKey   String
  serviceMode FbServiceMode?
  notes       String?

  ticketStatus OutletTicketStatus @default(NEW)

  /// Last outlet WhatsApp notify attempt (aligned with ticket; internal board stays source of truth).
  whatsappNotifyAt     DateTime?
  whatsappNotifyOk     Boolean?
  whatsappNotifyDetail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hotelId, ticketStatus])
  @@index([hotelId, outletKey])
  @@index([hotelId, createdAt])
}

model HousekeepingTask {
  id                String                 @id @default(cuid())
  hotelId           String
  hotel             Hotel                  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomUnitId        String
  roomUnit          RoomUnit               @relation(fields: [roomUnitId], references: [id], onDelete: Cascade)
  status            HousekeepingTaskStatus @default(PENDING)
  source            HousekeepingTaskSource
  bookingId         String?
  booking           Booking?               @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  assignedToUserId  String?
  assignedTo        HotelUser?             @relation("HKTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignmentMode    HousekeepingAssignmentMode?
  manualAssignedByUserId String?
  manualAssignedBy  HotelUser?             @relation("HKTaskManualAssignedBy", fields: [manualAssignedByUserId], references: [id], onDelete: SetNull)
  claimedAt         DateTime?
  createdByUserId   String?
  createdBy         HotelUser?             @relation("HKTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  completedByUserId String?
  completedBy       HotelUser?             @relation("HKTaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([hotelId, status])
  @@index([hotelId, roomUnitId])
  @@index([assignedToUserId])
}

model RoomUnit {
  id         String   @id @default(cuid())
  hotelId    String
  hotel      Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int?
  isActive   Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  bookings   Booking[]
  folioTransactions FolioTransaction[]
  folios     Folio[]
  housekeepingTasks HousekeepingTask[]

  @@unique([roomTypeId, name])
  @@index([hotelId, roomTypeId, isActive])
}

model Plan {
  id                     String         @id @default(cuid())
  code                   String         @unique
  name                   String
  description            String?
  billingCycle           BillingCycle   @default(MONTHLY)
  monthlyPrice           Float
  maxProperties          Int            @default(1)
  maxRoomTypes           Int            @default(20)
  maxMonthlyConversations Int           @default(2000)
  supportsChannelManager Boolean        @default(false)
  supportsCustomBranding Boolean        @default(false)
  supportsAiAutomation   Boolean        @default(true)
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  subscriptions          Subscription[]
}

model Subscription {
  id                    String             @id @default(cuid())
  hotelId               String
  hotel                 Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status                SubscriptionStatus @default(TRIALING)
  startedAt             DateTime           @default(now())
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  externalCustomerId    String?
  externalSubscriptionId String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  invoices              Invoice[]

  @@index([hotelId, status])
}

model Invoice {
  id                   String        @id @default(cuid())
  hotelId              String
  hotel                Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  subscriptionId       String?
  subscription         Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  externalInvoiceId    String?
  amountSubtotal       Float
  amountTax            Float         @default(0)
  amountTotal          Float
  currency             String        @default("OMR")
  status               InvoiceStatus @default(OPEN)
  dueAt                DateTime?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  paymentIntents       PaymentIntent[]

  @@index([hotelId, status])
}

model PaymentIntent {
  id                String         @id @default(cuid())
  hotelId           String
  hotel             Hotel          @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookingId         String?
  booking           Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  invoiceId         String?
  invoice           Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  kind              PaymentKind
  provider          String         @default("stripe")
  externalIntentId  String?
  amount            Float
  currency          String         @default("OMR")
  status            PaymentStatus  @default(PENDING)
  paymentLinkUrl    String?
  /// When the payment link was sent to the guest (e.g. WhatsApp); audit only.
  paymentLinkSentAt DateTime?
  metadataJson      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  transactions      PaymentTransaction[]

  @@index([hotelId, status])
}

model PaymentTransaction {
  id               String        @id @default(cuid())
  hotelId          String
  hotel            Hotel         @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  paymentIntentId  String
  paymentIntent    PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  externalTxnId    String?
  amount           Float
  currency         String        @default("OMR")
  status           PaymentStatus
  providerPayload  String?
  createdAt        DateTime      @default(now())
}

model IntegrationConnection {
  id                    String          @id @default(cuid())
  hotelId               String
  hotel                 Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  provider              ChannelProvider
  status                String          @default("disconnected")
  externalHotelId       String?
  credentialReference   String?
  lastSyncedAt          DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  mappings              ChannelMapping[]
  syncJobs              SyncJob[]

  @@unique([hotelId, provider])
}

model ChannelMapping {
  id                     String                @id @default(cuid())
  integrationConnectionId String
  integrationConnection  IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
  roomTypeId             String
  roomType               RoomType              @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  externalRoomId         String
  createdAt              DateTime              @default(now())

  @@unique([integrationConnectionId, roomTypeId])
}

model SyncJob {
  id                     String                @id @default(cuid())
  integrationConnectionId String
  integrationConnection  IntegrationConnection @relation(fields: [integrationConnectionId], references: [id], onDelete: Cascade)
  action                 String
  status                 SyncStatus            @default(QUEUED)
  errorMessage           String?
  startedAt              DateTime?
  finishedAt             DateTime?
  createdAt              DateTime              @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  hotelId     String
  hotel       Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  actorUserId String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String?
  /// When the audit entry concerns a booking, set for faster filtering (optional).
  bookingId   String?
  booking     Booking? @relation("BookingAuditLogs", fields: [bookingId], references: [id], onDelete: SetNull)
  metadataJson String?
  createdAt   DateTime @default(now())

  @@index([hotelId, createdAt])
  @@index([hotelId, bookingId])
  @@index([hotelId, propertyId, createdAt])
}

/// Durable notification record (in-app / future email & push). Phase 1: store only; no sender worker yet.
model Notification {
  id          String             @id @default(cuid())
  hotelId     String
  hotel       Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestId     String?
  guest       Guest?             @relation(fields: [guestId], references: [id], onDelete: SetNull)
  propertyId  String?
  property    Property?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  hotelUserId String?
  hotelUser   HotelUser?         @relation(fields: [hotelUserId], references: [id], onDelete: SetNull)
  channel     String             @default("IN_APP")
  type        String
  title       String?
  body        String
  status      NotificationStatus @default(PENDING)
  payloadJson String?
  readAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())

  @@index([hotelId, status])
  @@index([hotelId, guestId])
  @@index([hotelId, propertyId])
  @@index([hotelId, hotelUserId])
  @@index([hotelId, createdAt])
}

/// Lightweight auto-followup queue for recovery and re-engagement messages.
model GuestFollowUp {
  id             String   @id @default(cuid())
  hotelId        String
  hotel          Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestId        String
  guest          Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  propertyId     String?
  property       Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  bookingId      String?
  booking        Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  type           String
  status         String   @default("PENDING")
  dedupeKey      String   @unique
  scheduledFor   DateTime
  sentAt         DateTime?
  cancelledAt    DateTime?
  payloadJson    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([hotelId, status, scheduledFor])
  @@index([hotelId, guestId, type])
  @@index([hotelId, propertyId, status, scheduledFor])
}

model ConversationSession {
  id             String       @id @default(cuid())
  hotelId        String
  hotel          Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestId        String
  guest          Guest        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  phoneE164      String
  language       String       @default("en")
  stage          String       @default("IDLE")
  metadataJson   String?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([hotelId, guestId])
  @@index([hotelId, stage])
  @@index([hotelId, phoneE164])
}

model BookingDraft {
  id             String       @id @default(cuid())
  hotelId        String
  hotel          Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestId        String
  guest          Guest        @relation(fields: [guestId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  bookingId      String?      @unique
  booking        Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  source         String       @default("WHATSAPP")
  status         String       @default("OPEN")
  checkIn        DateTime?
  checkOut       DateTime?
  adults         Int          @default(2)
  rooms          Int          @default(1)
  guestName      String?
  roomTypeId     String?
  roomTypeName   String?
  propertyId     String?
  nightlyRate    Float?
  totalAmount    Float?
  currency       String       @default("OMR")
  metadataJson   String?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([hotelId, guestId, status])
  @@index([hotelId, checkIn, checkOut])
}

/// One row per calendar digest day (timezone in env OWNER_DIGEST_TZ); audit trail for owner daily email.
model OwnerDailyDigestLog {
  id            String    @id @default(cuid())
  /// YYYY-MM-DD civil date in digest timezone when the run was for.
  digestKey     String    @unique
  status        String
  recipient     String?
  subject       String?
  errorMessage  String?
  /// JSON array of platform alert ids at send time (for “new since last” on next send).
  alertIdsJson  String?
  newAlertCount Int?
  /// Compact JSON for history UI (KPIs headline).
  summaryJson   String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CalendarSession {
  id             String       @id @default(cuid())
  hotelId        String
  hotel          Hotel        @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  guestId        String?
  guest          Guest?       @relation(fields: [guestId], references: [id], onDelete: SetNull)
  tokenHash      String       @unique
  phoneE164      String
  language       String       @default("en")
  intentSource   String       @default("WHATSAPP")
  metadataJson   String?
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([hotelId, expiresAt])
  @@index([hotelId, phoneE164])
}
