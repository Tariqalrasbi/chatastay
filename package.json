{
  "name": "chatastay",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:3001": "PORT=3001 tsx watch src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate:deploy": "node scripts/migrate-deploy.cjs",
    "backup:db": "node scripts/backup-sqlite.cjs",
    "backup:daily": "bash scripts/cron-daily-backup.sh",
    "backup:upload:s3": "node scripts/upload-latest-backup-s3.cjs",
    "bootstrap:foundation": "node scripts/bootstrap-foundation.cjs",
    "inspect:db": "node scripts/inspect-production-data.cjs",
    "restore:db": "node scripts/restore-sqlite.cjs",
    "start:with-migrate": "node scripts/migrate-deploy.cjs && prisma generate && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "seed:outlet-menu": "node scripts/seed-outlet-menu.cjs",
    "smoke:webhook": "tsx scripts/smoke-webhook.ts",
    "test:e2e:calendar": "tsx scripts/e2e-calendar-dryrun.ts",
    "smoke:all": "npm run smoke:webhook && npm run test:e2e:calendar"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@prisma/client": "^6.4.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.6",
    "pdfkit": "^0.17.2",
    "stripe": "^18.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.17.5",
    "prisma": "^6.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
