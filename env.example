NODE_ENV=development
PORT=3000

DATABASE_URL="file:./dev.db"

# Optional: default hotel slug for single-tenant installs (room board, profile). Defaults to al-ashkhara-beach-resort.
# DEFAULT_HOTEL_SLUG=al-ashkhara-beach-resort

# See .env.example for WhatsApp token renewal (Meta code 190 = new WHATSAPP_TOKEN required).
WHATSAPP_TOKEN=replace-me
WHATSAPP_VERIFY_TOKEN=replace-me
WHATSAPP_PHONE_NUMBER_ID=replace-me
