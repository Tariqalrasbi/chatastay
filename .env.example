NODE_ENV=development
PORT=3000

DATABASE_URL="file:./dev.db"

# Admin PMS routes resolve the tenant hotel by slug. Must match a row in Hotel.slug (see npm run inspect:db).
# DEFAULT_HOTEL_SLUG=al-ashkhara-beach-resort

# Callback URL in Meta must be: https://YOUR_PUBLIC_HOST/whatsapp/webhook (GET for verify; POST for messages)
#
# Outbound messages (Graph API): WHATSAPP_TOKEN + WHATSAPP_PHONE_NUMBER_ID must be valid or sends fail (Meta error 190 = expired/invalid token).
# Renew: Meta Business Suite → Business settings → Users → System users → Add/Select → Generate new token (assign WhatsApp app + whatsapp_business_messaging),
#   OR WhatsApp Manager → API setup → copy Phone number ID here and use a token that includes this WABA.
# Long-lived tokens can expire; replace WHATSAPP_TOKEN and restart when logs show OAuth/code 190.
WHATSAPP_TOKEN=replace-me
# Must match Meta "Verify token" exactly (no extra spaces). Used only for webhook subscription, not Graph API.
WHATSAPP_VERIFY_TOKEN=replace-me
# Digits only — from Meta → WhatsApp → API setup → "Phone number ID" (must match the same WABA as WHATSAPP_TOKEN).
WHATSAPP_PHONE_NUMBER_ID=replace-me
STRIPE_SECRET_KEY=
APP_BASE_URL=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_WEBHOOK_SECRET=
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@chatastay.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
