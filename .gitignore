# Timestamped DB snapshots from npm run backup:db
backups/sqlite/*.db
backups/sqlite/*.db-wal
backups/sqlite/*.db-shm

logs/*.log

# Runtime-managed admin permissions cache (written by the server at runtime,
# must not be tracked or auto-deploy will fight runtime writes on every pull).
admin-user-permissions.json

