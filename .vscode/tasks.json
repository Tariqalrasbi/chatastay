{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ChatAStay: dev server (port 3000)",
      "type": "npm",
      "script": "dev",
      "path": "package.json",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "showReuseMessage": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "runOptions": {
        "instanceLimit": 1,
        "reentrancy": "terminateOther"
      }
    },
    {
      "label": "ChatAStay: dev server (port 3001 — if 3000 is busy)",
      "type": "npm",
      "script": "dev:3001",
      "path": "package.json",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "showReuseMessage": false
      },
      "group": "build"
    }
  ]
}
